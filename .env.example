# .env.example
# This file contains all the environment variables needed by the application.
# Copy this file to .env and fill in the appropriate values for your local setup.

# ---------------------------------
# SERVER CONFIGURATION
# ---------------------------------
# The port the application will run on.
SERVER_PORT=8080
# Application name and environment (e.g., development, staging, production).
SERVER_APP_NAME="Casbin DB API"
SERVER_APP_ENV=development
# Timeouts for server connections.
SERVER_READ_TIMEOUT=30s
SERVER_WRITE_TIMEOUT=30s

# ---------------------------------
# LOGGER CONFIGURATION
# ---------------------------------
# Log level (e.g., debug, info, warn, error, fatal, panic).
LOG_LEVEL=info

# ---------------------------------
# POSTGRESQL DATABASE CONFIGURATION
# ---------------------------------
#POSTGRES_HOST=localhost
#POSTGRES_PORT=5432
#POSTGRES_USER=your_postgres_user
#POSTGRES_PASSWORD=your_postgres_password
#POSTGRES_DBNAME=your_database_name

# ---------------------------------
# MYSQL DATABASE CONFIGURATION
# ---------------------------------
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=your_mysql_user
MYSQL_PASSWORD=Password0!
MYSQL_DBNAME=gin_starter_db
MYSQL_IDLE_CONNECTION=10
MYSQL_MAX_CONNECTION=100
MYSQL_MAX_LIFE_TIME_CONNECTION=3600

# ---------------------------------
# REDIS CONFIGURATION
# ---------------------------------
# Address for the Redis server.
REDIS_ADDR=localhost:6379
# Password for Redis. Leave blank if there is no password.
REDIS_PASSWORD=Password0!
# Redis database to use.
REDIS_DB=0
# Connection pool settings.
REDIS_POOL_SIZE=10
REDIS_DIAL_TIMEOUT=5s
REDIS_READ_TIMEOUT=3s
REDIS_WRITE_TIMEOUT=3s

# ---------------------------------
# JWT (JSON Web Token) CONFIGURATION
# ---------------------------------
# These MUST be set to long, random, and secret strings.
JWT_ACCESS_SECRET=your_very_secret_and_random_access_key
JWT_REFRESH_SECRET=your_very_secret_and_random_refresh_key

# Token durations (e.g., 15m for minutes, 1h for hours).
JWT_ACCESS_DURATION=15m
JWT_REFRESH_DURATION=24h

# ---------------------------------
# WEBSOCKET CONFIGURATION
# ---------------------------------
WEBSOCKET_WRITE_WAIT=10s
WEBSOCKET_PONG_WAIT=60s
WEBSOCKET_MAX_MESSAGE_SIZE=512

# ---------------------------------
# CASBIN CONFIGURATION
# ---------------------------------
CASBIN_ENABLED=true
CASBIN_MODEL=internal/config/casbin_model.conf
CASBIN_WATCHER_ENABLED=false
CASBIN_WATCHER_CHANNEL=/casbin