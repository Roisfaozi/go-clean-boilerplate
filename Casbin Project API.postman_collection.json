	"item": [
		{
            "name": "Users",
            "item": [
                {
                    "name": "Register New User",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test(\"Status code is 201\", function () {",
                                    "    pm.response.to.have.status(201);",
                                    "});",
                                    "",
                                    "pm.test(\"Response should be a valid JSON\", function () {",
                                    "    pm.response.to.be.json;",
                                    "});",
                                    "",
                                    "pm.test(\"Response data should contain userId\", function () {",
                                    "    const jsonData = pm.response.json();",
                                    "    pm.expect(jsonData.data).to.have.property('userId');",
                                    "    pm.expect(jsonData.data.userId).to.be.a('string');",
                                    "});",
                                    "",
                                    "// Save the userId and credentials for subsequent requests",
                                    "const jsonData = pm.response.json();",
                                    "if (jsonData.data && jsonData.data.userId) {",
                                    "    pm.environment.set(\"userId\", jsonData.data.userId);",
                                    "    // Set credentials for the login request",
                                    "    const username = pm.variables.get(\"newUsername\") + \"-\" + pm.variables.get(\"$timestamp\");",
                                    "    pm.environment.set(\"username\", username);",
                                    "    pm.environment.set(\"password\", pm.variables.get(\"newPassword\"));",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"username\": \"{{newUsername}}-{{$timestamp}}\",\n    \"password\": \"{{newPassword}}\",\n    \"fullname\": \"{{newFullname}}\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{baseURL}}/users",
                            "host": [
                                "{{baseURL}}"
                            ],
                            "path": [
                                "users"
                            ]
                        }
                    },
                    "response": []
                },
                {
                    "name": "Register User with Existing Username",
                    "event": [
                        {
                            "listen": "prerequest",
                            "script": {
                                "exec": [
                                    "// This script ensures a user exists before attempting to register with the same username.",
                                    "const registerUserRequest = {",
                                    "  url: `${pm.environment.get(\"baseURL\")/users`,",
                                    "  method: 'POST',",
                                    "  header: 'Content-Type:application/json',",
                                    "  body: {",
                                    "    mode: 'raw',",
                                    "    raw: JSON.stringify({",
                                    "      username: pm.environment.get(\"username\"),",
                                    "      password: pm.environment.get(\"password\"),",
                                    "      fullname: pm.variables.get(\"newFullname\")",
                                    "    })",
                                    "  }",
                                    "};",
                                    "",
                                    "pm.sendRequest(registerUserRequest, (err, res) => {});"
                                ],
                                "type": "text/javascript"
                            }
                        },
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test(\"Status code is 400\", function () {",
                                    "    pm.response.to.have.status(400);",
                                    "});",
                                    "",
                                    "pm.test(\"Error message should indicate username is taken\", function () {",
                                    "    const jsonData = pm.response.json();",
                                    "    pm.expect(jsonData.status).to.eql('fail');",
                                    "    pm.expect(jsonData.message).to.contain('username already taken');",
                                    "});"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"username\": \"{{username}}\",\n    \"password\": \"{{password}}\",\n    \"fullname\": \"{{newFullname}}\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{baseURL}}/users",
                            "host": [
                                "{{baseURL}}"
                            ],
                            "path": [
                                "users"
                            ]
                        }
                    },
                    "response": []
                },
                {
                    "name": "Register User with Bad Payload",
                    "event": [
                        {
                            "listen": "prerequest",
                            "script": {
                                "exec": [
                                    "let badUserPayloads = pm.environment.get('badUserPayloads');",
                                    "if (!badUserPayloads || badUserPayloads.length === 0) {",
                                    "    badUserPayloads = [",
                                    "        {},",
                                    "        { password: 'password123', fullname: 'Test User' },",
                                    "        { username: 'testuser', fullname: 'Test User' },",
                                    "        { username: 'testuser', password: 'password123' },",
                                    "        { username: 123, password: 'password123', fullname: 'Test User' },",
                                    "        { username: 'testuser', password: 123, fullname: 'Test User' }",
                                    "    ];",
                                    "}",
                                    "const currentPayload = badUserPayloads.shift();",
                                    "pm.environment.set('currentBadUserPayload', JSON.stringify(currentPayload));",
                                    "pm.environment.set('badUserPayloads', badUserPayloads);"
                                ],
                                "type": "text/javascript"
                            }
                        },
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test(\"Status code is 400\", function () {",
                                    "    pm.response.to.have.status(400);",
                                    "});",
                                    "",
                                    "// Loop until all bad payloads are tested",
                                    "const badUserPayloads = pm.environment.get('badUserPayloads');",
                                    "if (badUserPayloads && badUserPayloads.length > 0) {",
                                    "    postman.setNextRequest('Register User with Bad Payload');",
                                    "} else {",
                                    "    pm.environment.unset('badUserPayloads');",
                                    "    pm.environment.unset('currentBadUserPayload');",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [],
                        "body": {
                            "mode": "raw",
                            "raw": "{{currentBadUserPayload}}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{baseURL}}/users",
                            "host": [
                                "{{baseURL}}"
                            ],
                            "path": [
                                "users"
                            ]
                        }
                    },
                    "response": []
                },
                {
                    "name": "[SECURITY] POST User with Malformed JSON",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test(\"Status should be 400 Bad Request\", function () {",
                                    "    pm.response.to.have.status(400);",
                                    "});",
                                    "",
                                    "pm.test(\"Response message should be generic and safe\", function () {",
                                    "    const jsonData = pm.response.json();",
                                    "    pm.expect(jsonData.status).to.eql('fail');",
                                    "    const responseText = pm.response.text().toLowerCase();",
                                    "    pm.expect(responseText).to.not.include('panic');",
                                    "    pm.expect(responseText).to.not.include('stack');",
                                    "    pm.expect(responseText).to.not.include('error');",
                                    "});"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\\n    \"username\": \"malformed\",\\n    \"password\": \"malformedpass\",\\n    \"fullname\": \"Malformed User\"\\n,"
                        },
                        "url": {
                            "raw": "{{baseURL}}/users",
                            "host": [
                                "{{baseURL}}"
                            ],
                            "path": [
                                "users"
                            ]
                        }
                    },
                    "response": []
                },
                {
                    "name": "Get User by ID",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test(\"Status code is 200\", function () { pm.response.to.have.status(200); });",
                                    "pm.test(\"Response data should contain the correct user\", function () {",
                                    "    const jsonData = pm.response.json();",
                                    "    pm.expect(jsonData.data.user.id).to.eql(pm.environment.get(\"userId\"));",
                                    "});"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "auth": { "type": "bearer", "bearer": [ { "key": "token", "value": "{{authToken}}", "type": "string" } ] },
                        "method": "GET",
                        "url": { "raw": "{{baseURL}}/users/{{userId}}", "host": [ "{{baseURL}}" ], "path": [ "users", "{{userId}}" ] }
                    }
                },
                {
                    "name": "Update User by ID",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test(\"Status code is 200\", function () { pm.response.to.have.status(200); });",
                                    "// Verify the update by fetching the user again",
                                    "pm.sendRequest(`${pm.environment.get(\"baseURL\")}/users/${pm.environment.get(\"userId\")}`, {",
                                    "    method: 'GET',",
                                    "    headers: { 'Authorization': 'Bearer ' + pm.environment.get('authToken') }",
                                    "}, function (err, response) {",
                                    "    if (!err) {",
                                    "        pm.test('User fullname should be updated', () => {",
                                    "            pm.expect(response.json().data.user.fullname).to.eql(pm.environment.get(\"updatedFullname\"));",
                                    "        });",
                                    "    }",
                                    "});"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "auth": { "type": "bearer", "bearer": [ { "key": "token", "value": "{{authToken}}", "type": "string" } ] },
                        "method": "PUT",
                        "body": { "mode": "raw", "raw": "{\n    \"fullname\": \"{{updatedFullname}}\"\n}", "options": { "raw": { "language": "json" } } },
                        "url": { "raw": "{{baseURL}}/users/{{userId}}", "host": [ "{{baseURL}}" ], "path": [ "users", "{{userId}}" ] }
                    }
                },
                {
                    "name": "Delete User by ID",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test(\"Status code is 200\", function () { pm.response.to.have.status(200); });",
                                    "// Verify the deletion by fetching the user again",
                                    "pm.sendRequest(`${pm.environment.get(\"baseURL\")}/users/${pm.environment.get(\"userId\")}`, {",
                                    "    method: 'GET',",
                                    "    headers: { 'Authorization': 'Bearer ' + pm.environment.get('authToken') }",
                                    "}, function (err, response) {",
                                    "    if (!err) {",
                                    "        pm.test('User should be deleted (expect 404)', () => {",
                                    "            pm.expect(response.code).to.equal(404);",
                                    "        });",
                                    "    }",
                                    "});"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "auth": { "type": "bearer", "bearer": [ { "key": "token", "value": "{{authToken}}", "type": "string" } ] },
                        "method": "DELETE",
                        "url": { "raw": "{{baseURL}}/users/{{userId}}", "host": [ "{{baseURL}}" ], "path": [ "users", "{{userId}}" ] }
                    }
                }
            ],
            "description": "Requests for managing user resources (CRUD)."
        },
