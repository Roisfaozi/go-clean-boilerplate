                                    "// Verify the deletion by fetching policies again",
                                    "pm.sendRequest(`${pm.environment.get(\"baseURL\")}/permissions`, {",
                                    "    method: 'GET',",
                                    "    headers: { 'Authorization': 'Bearer ' + pm.environment.get('authToken') }",
                                    "}, function (err, response) {",
                                    "    if (!err) {",
                                    "        pm.test('The policy should be removed', () => {",
                                    "            const jsonData = response.json();",
                                    "            const policyToRemove = [\"role_editor\", \"/articles\", \"write\"];",
                                    "            const found = jsonData.data.policies.some(p => ",
                                    "                p[0] === policyToRemove[0] && ",
                                    "                p[1] === policyToRemove[1] && ",
                                    "                p[2] === policyToRemove[2]",
                                    "            );",
                                    "            pm.expect(found).to.be.false;",
                                    "        });",
                                    "    }",
                                    "});"
                                ],
                                "type": "text/javascript"
                            }
