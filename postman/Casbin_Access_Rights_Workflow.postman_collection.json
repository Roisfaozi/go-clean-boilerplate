{
	"info": {
		"name": "Casbin Access Rights Workflow",
		"description": "Demonstrates the workflow of defining Access Rights as a catalog and applying them to users via Roles.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "[SETUP] Admin Login",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Status code is 200\", function () {",
							"    pm.response.to.have.status(200);",
							"});",
							"var jsonData = pm.response.json();",
							"if (jsonData.data && jsonData.data.access_token) {",
							"    pm.environment.set(\"adminToken\", jsonData.data.access_token);",
							"}"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"username\": \"{{superAdminUsername}}\",\n    \"password\": \"{{superAdminPassword}}\"\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{baseURL}}/{{apiVersion}}/auth/login",
					"host": [
						"{{baseURL}}"
					],
					"path": [
						"{{apiVersion}}",
						"auth",
						"login"
					]
				}
			}
		},
		{
			"name": "[PHASE 1] Define Catalog",
			"item": [
				{
					"name": "1. Create Endpoint (Resource)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 201\", function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"var jsonData = pm.response.json();",
									"pm.environment.set(\"endpointId\", jsonData.data.id);",
									"pm.environment.set(\"targetPath\", jsonData.data.path);",
									"pm.environment.set(\"targetMethod\", jsonData.data.method);"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{adminToken}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"path\": \"/api/v1/documents/secret-report\",\n    \"method\": \"GET\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseURL}}/{{apiVersion}}/endpoints",
							"host": [
								"{{baseURL}}"
							],
							"path": [
								"{{apiVersion}}",
								"endpoints"
							]
						}
					}
				},
				{
					"name": "2. Create Access Right (Logical Feature)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 201\", function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"var jsonData = pm.response.json();",
									"pm.environment.set(\"accessRightId\", jsonData.data.id);"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{adminToken}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"view_secret_reports\",\n    \"description\": \"Allows reading secret reports\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseURL}}/{{apiVersion}}/access-rights",
							"host": [
								"{{baseURL}}"
							],
							"path": [
								"{{apiVersion}}",
								"access-rights"
							]
						}
					}
				},
				{
					"name": "3. Link Endpoint to Access Right",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{adminToken}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"access_right_id\": {{accessRightId}},\n    \"endpoint_id\": {{endpointId}}\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseURL}}/{{apiVersion}}/access-rights/link",
							"host": [
								"{{baseURL}}"
							],
							"path": [
								"{{apiVersion}}",
								"access-rights",
								"link"
							]
						}
					}
				}
			]
		},
		{
			"name": "[PHASE 2] User & Role Setup",
			"item": [
				{
					"name": "1. Register User (Budi)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 201\", function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"var jsonData = pm.response.json();",
									"pm.environment.set(\"budiId\", jsonData.data.id);",
									"pm.environment.set(\"budiUsername\", jsonData.data.username);"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"budi_{{$timestamp}}\",\n    \"password\": \"password123\",\n    \"name\": \"Budi Santoso\",\n    \"email\": \"budi_{{$timestamp}}@example.com\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseURL}}/{{apiVersion}}/users/register",
							"host": [
								"{{baseURL}}"
							],
							"path": [
								"{{apiVersion}}",
								"users",
								"register"
							]
