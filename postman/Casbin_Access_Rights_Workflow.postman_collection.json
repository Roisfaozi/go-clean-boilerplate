					}
				},
				{
					"name": "2. Create Role (Editor)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 201\", function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"var jsonData = pm.response.json();",
									"pm.environment.set(\"targetRole\", \"role:editor\");",
									"pm.environment.set(\"editorRoleId\", jsonData.data.id);"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{adminToken}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"name\": \"role:editor\",\n    \"description\": \"Editor role\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseURL}}/{{apiVersion}}/roles",
							"host": [
								"{{baseURL}}"
							],
							"path": [
								"{{apiVersion}}",
								"roles"
							]
						}
					}
				},
				{
					"name": "3. Assign Role Editor to Budi",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{adminToken}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"user_id\": \"{{budiId}}\",\n    \"role\": \"role:editor\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseURL}}/{{apiVersion}}/permissions/assign-role",
							"host": [
								"{{baseURL}}"
							],
							"path": [
								"{{apiVersion}}",
								"permissions",
								"assign-role"
							]
						}
					}
				}
			]
		},
		{
			"name": "[PHASE 3] Apply Permission",
			"item": [
				{
					"name": "1. Grant Access Right to Role",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{adminToken}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"role\": \"{{targetRole}}\",\n    \"path\": \"{{targetPath}}\",\n    \"method\": \"{{targetMethod}}\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseURL}}/{{apiVersion}}/permissions/grant",
							"host": [
								"{{baseURL}}"
							],
							"path": [
								"{{apiVersion}}",
								"permissions",
								"grant"
							]
						}
					}
				}
			]
		},
		{
			"name": "[PHASE 4] Verify Access",
			"item": [
				{
					"name": "1. Login Budi (Refresh Token for New Role)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"var jsonData = pm.response.json();",
									"pm.environment.set(\"budiToken\", jsonData.data.access_token);",
									"pm.test(\"Role updated to editor\", function () {",
									"    pm.expect(jsonData.data.user.role).to.eql(\"role:editor\");",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"{{budiUsername}}\",\n    \"password\": \"password123\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseURL}}/{{apiVersion}}/auth/login",
							"host": [
								"{{baseURL}}"
							],
							"path": [
								"{{apiVersion}}",
								"auth",
								"login"
							]
						}
					}
				},
				{
					"name": "2. Access Secret Document (Success)",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{budiToken}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseURL}}{{targetPath}}",
							"host": [
								"{{baseURL}}"
							],
							"path": [
								"{{targetPath}}"
							]
						}
					}
				}
			]
		},
