{
	"info": {
		"name": "Casbin API Full Flow",
		"description": "A comprehensive end-to-end flow testing user registration, authentication, role assignment, and RBAC enforcement using Casbin.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "[SETUP] Admin & Permissions",
			"item": [
				{
					"name": "1. Register Admin User",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 201\", function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"",
									"var jsonData = pm.response.json();",
									"if (jsonData.data && jsonData.data.id) {",
									"    pm.environment.set(\"adminUserId\", jsonData.data.id);",
									"    pm.environment.set(\"adminUsername\", jsonData.data.username);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"admin_{{$timestamp}}\",\n    \"password\": \"password123\",\n    \"name\": \"Admin User\",\n    \"email\": \"admin_{{$timestamp}}@example.com\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseURL}}/{{apiVersion}}/users/register",
							"host": [
								"{{baseURL}}"
							],
							"path": [
								"{{apiVersion}}",
								"users",
								"register"
							]
						}
					}
				},
				{
					"name": "2. Login Admin",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"var jsonData = pm.response.json();",
									"if (jsonData.data && jsonData.data.access_token) {",
									"    pm.environment.set(\"adminToken\", jsonData.data.access_token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"{{adminUsername}}\",\n    \"password\": \"password123\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseURL}}/{{apiVersion}}/auth/login",
							"host": [
								"{{baseURL}}"
							],
							"path": [
								"{{apiVersion}}",
								"auth",
								"login"
							]
						}
					}
				},
				{
					"name": "3. Assign Admin Role",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{adminToken}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"user_id\": \"{{adminUserId}}\",\n    \"role\": \"role:admin\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseURL}}/{{apiVersion}}/permissions/assign-role",
							"host": [
								"{{baseURL}}"
							],
							"path": [
								"{{apiVersion}}",
								"permissions",
								"assign-role"
							]
						}
					}
				},
				{
					"name": "4. Grant Permission (Get All Users)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 201\", function () {",
									"    pm.response.to.have.status(201);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{adminToken}}",
									"type": "string"
								}
							]
						},
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"role\": \"role:admin\",\n    \"path\": \"/api/v1/users\",\n    \"method\": \"GET\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseURL}}/{{apiVersion}}/permissions/grant",
							"host": [
								"{{baseURL}}"
							],
							"path": [
								"{{apiVersion}}",
								"permissions",
								"grant"
							]
						}
					}
				}
			]
		},
