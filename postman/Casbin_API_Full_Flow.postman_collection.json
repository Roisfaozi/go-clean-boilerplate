		},
		{
			"name": "[CLEANUP]",
			"item": [
				{
					"name": "1. Delete Normal User",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{adminToken}}",
									"type": "string"
								}
							]
						},
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{baseURL}}/{{apiVersion}}/users/{{normalUserId}}",
							"host": [
								"{{baseURL}}"
							],
							"path": [
								"{{apiVersion}}",
								"users",
								"{{normalUserId}}"
							]
						}
					}
				},
